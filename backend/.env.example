NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/fermi_db?schema=public
JWT_SECRET=change_me_super_secret_at_least_32_chars
JWT_EXPIRES_IN=1d
UPLOAD_DIR=uploads
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
PLATFORM_PORT=4100
PLATFORM_CORS_ORIGIN=http://localhost:5174
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=gestionalefermi@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Gestione Fermi <gestionalefermi@gmail.com>"
CRON_REMINDER_SCHEDULE=*/10 * * * *
SLA_PRIORITY_THRESHOLDS={"LOW":15,"MEDIUM":10,"HIGH":5,"CRITICAL":2}
PLATFORM_ADMIN_EMAIL=platform.admin@local.test
PLATFORM_ADMIN_PASSWORD=replace_with_strong_password_min_20_chars
PLATFORM_JWT_SECRET=replace_with_platform_jwt_secret_min_64_chars
PLATFORM_JWT_EXPIRES_IN=15m
PLATFORM_ALLOWED_IPS=127.0.0.1,::1,203.0.113.10
PLATFORM_ALERT_EMAILS=security@example.com,owner@example.com
PLATFORM_BIND_HOST=127.0.0.1
PLATFORM_LOGIN_MAX_ATTEMPTS=5
PLATFORM_LOGIN_WINDOW_MS=900000
PLATFORM_LOGIN_LOCK_MS=1800000
